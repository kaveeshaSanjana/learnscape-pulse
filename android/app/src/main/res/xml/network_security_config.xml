<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration for Suraksha LMS
  - Enforces HTTPS for all connections
  - Only allows cleartext (HTTP) on localhost for Capacitor live-reload during development
  - Production: all traffic is encrypted
-->
<network-security-config>
    <!-- Block cleartext (HTTP) traffic by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext only for localhost (needed for Capacitor dev server) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>

  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite --port=3000 --host=127.0.0.1",
    "dev:network": "vite --port=3000 --host=0.0.0.0",
    "clean": "node -e \"try{require('fs').rmSync('dist',{recursive:true,force:true})}catch(e){process.stderr.write(e.message+'\\n');process.exit(1)}\"",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build --mode production --logLevel error",
    "build:dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build --mode development",
    "build:prod": "npm run --silent build",
    "build:verbose": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build --mode production",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "cap:build": "npm run --silent clean && npm run --silent build && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android"
  },
